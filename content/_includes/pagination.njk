<nav class="pagination" aria-labelledby="blog-pagination">
    {% if pagination.href.previous %}
        <span class="arrows">
            <a href="{{ pagination.href.previous }}" rel="prev">
                <i class="fa fa-chevron-circle-left"></i>
            </a>
        </span>
    {% else %}
        <span class="arrows arrows-inactive">
            <i class="fa fa-chevron-circle-left"></i>
        </span>
    {% endif %}
    {%- for pageEntry in pagination.pages %}
        <span class="items {% if page.url == pagination.hrefs[ loop.index0 ] %} current-item{% endif %}">
            <a href="{{ pagination.hrefs[ loop.index0 ] }}"{% if page.url == pagination.hrefs[ loop.index0 ] %} aria-current="page"{% endif %}>{{ loop.index0 }}</a>
        </span>
    {%- endfor %}
    {% if pagination.href.next %}
        <span class="arrows">
            <a href="{{ pagination.href.next }}" rel="next">
                <i class="fa fa-chevron-circle-right"></i>
            </a>
        </span>
    {% else %}
        <span class="arrows arrows-inactive">
            <i class="fa fa-chevron-circle-right"></i>
        </span>
    {% endif %}
</nav>