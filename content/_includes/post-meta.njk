{% if post.data | length %}
    {% set date = post.date %}
    {% set category = post.data.category %}
    {% set content = post.templateContent %}
    {% set url = post.url | url %}
{% endif %}

{% set categories = category.split("|") %}

<div class="entry-meta">
    <span class="entry-meta-item">
        {% for cat in categories %}
            <a href="/blog/{{ cat | slug }}/" rel="category">{{ cat }}</a>
            {% if not loop.last %}/{% endif %}
        {% endfor %}
    </span>
    <span class="entry-meta-item">
        <time datetime="{{ date | dateIso }}">{{ date | dateReadable }}</time>
    </span>
    <span class="entry-meta-item">
        {{ content | readingTime }}
    </span>
    <span class="entry-meta-item">
        <a href="{{ url }}#disqus_thread">0 comment</a>
    </span>
</div>