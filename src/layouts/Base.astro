---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal website of Nachiketa Das' } = Astro.props;
const siteTitle = 'Atekihcan';
const fullTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle}
      href="/rss.xml"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-content">
        <a href="/" class="site-logo">atekihcan</a>
        <nav class="site-nav">
          <a href="/blog/">Blog</a>
          <a href="/about/">About</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </div>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Nachiketa Das</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --primary: hsl(193, 100%, 30%);
    --primary-light: hsl(193, 100%, 50%);
    --text: #1a1a2e;
    --text-muted: #555;
    --bg: #fff;
    --bg-code: #f6f8fa;
    --border: #e1e4e8;
    --max-width: 720px;
    --font-sans: system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', ui-monospace,
      monospace;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-size: 17px;
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    color: var(--text);
    background: var(--bg);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--primary);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5rem auto;
    border-radius: 4px;
  }

  figure {
    margin: 1.5rem 0;
    text-align: center;
  }

  .site-header {
    background: var(--primary);
    color: #fff;
    padding: 1rem 1.5rem;
  }

  .header-content {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-logo {
    color: #fff !important;
    font-size: 1.4rem;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .site-logo:hover {
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    gap: 1.5rem;
  }

  .site-nav a {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .site-nav a:hover {
    color: #fff;
    text-decoration: none;
  }

  .site-main {
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    flex: 1;
  }

  .site-footer {
    text-align: center;
    padding: 2rem 1.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    border-top: 1px solid var(--border);
  }

  /* Typography for post content */
  .post-content h1,
  .post-content h2,
  .post-content h3,
  .post-content h4 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .post-content h2 {
    font-size: 1.5rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border);
  }

  .post-content h3 {
    font-size: 1.25rem;
  }

  .post-content p {
    margin-bottom: 1.25rem;
  }

  .post-content ul,
  .post-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-content li {
    margin-bottom: 0.5rem;
  }

  .post-content blockquote {
    border-left: 3px solid var(--primary);
    padding: 0.5rem 1rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    background: var(--bg-code);
  }

  .post-content code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--bg-code);
    padding: 0.15em 0.35em;
    border-radius: 3px;
  }

  .post-content pre {
    margin: 1.5rem 0;
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.88rem;
    line-height: 1.5;
    border: 1px solid var(--border);
  }

  .post-content pre code {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .post-content hr {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 2rem 0;
  }

  /* Highlight boxes from old posts */
  .highlight-red {
    padding: 1rem;
    margin: 1.5rem 0;
    background: rgba(220, 20, 60, 0.1);
    border-left: 3px solid crimson;
    border-radius: 4px;
  }

  .highlight-green {
    padding: 1rem;
    margin: 1.5rem 0;
    background: rgba(60, 179, 113, 0.1);
    border-left: 3px solid mediumseagreen;
    border-radius: 4px;
  }

  /* KaTeX overrides */
  .katex-display {
    overflow-x: auto;
    padding: 0.5rem 0;
  }

  @media (max-width: 600px) {
    html {
      font-size: 16px;
    }

    .header-content {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
