---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { postUrl } from '../lib/slugs';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Base title="Atekihcan">
  <section class="hero">
    <h1>Hey, I'm Nachiketa</h1>
    <p>
      I write about GPU architecture, AI systems, and things I learn along the
      way. This is my personal StackOverflow.
    </p>
  </section>

  <section>
    <h2 class="section-title">Recent Posts</h2>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <a href={postUrl(post)}>
              <span class="post-title">{post.data.title}</span>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </a>
          </li>
        ))
      }
    </ul>
    <p><a href="/blog/">View all posts &rarr;</a></p>
  </section>
</Base>

<style>
  .hero {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .hero h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .section-title {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 1rem;
    color: var(--text-muted);
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list li {
    margin-bottom: 0;
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    gap: 1rem;
  }

  .post-list a:hover {
    text-decoration: none;
    color: var(--primary);
  }

  .post-list time {
    color: var(--text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .post-title {
    font-weight: 500;
  }
</style>
